# Astra — Docker Compose configuration. Copy to .env and edit.
#   cp .env.example .env
# Every value is optional: with none set, the app runs fully (AI falls back to
# the on-device offline reflection). Compose reads this file automatically.

# --- Web ---------------------------------------------------------------------
# Host port the web app is published on — the SAME for dev and prod.
WEB_PORT=5173

# --- Backend environment / security -----------------------------------------
# development boots without a secret. Production REQUIRES a strong AAE_SECRET
# (openssl rand -hex 32) or the backend fails closed and refuses to start.
AAE_ENV=development
AAE_SECRET=

# --- AI provider routing -----------------------------------------------------
# auto = prefer local (kgirl/ollama) → cloud → offline.
AAE_AI_PROVIDER=auto

# Ollama (local models). The backend runs in a container, so "localhost" is the
# container itself — point OLLAMA_HOST at the host gateway to reach an Ollama on
# your machine (extra_hosts maps host.docker.internal in compose). If you run
# Ollama as its own compose service, set this to http://ollama:11434.
OLLAMA_HOST=http://host.docker.internal:11434
AAE_OLLAMA_MODEL=qwen2.5:3b
AAE_OLLAMA_MODEL_DEEP=

# Cloud (any OpenAI-compatible gateway: OpenRouter / OpenAI / Nous).
AAE_AI_API_KEY=
AAE_AI_BASE_URL=https://openrouter.ai/api/v1
AAE_AI_MODEL=anthropic/claude-haiku-4-5

# --- Premium voice (ElevenLabs, optional) -----------------------------------
ELEVENLABS_API_KEY=

# --- Swiss Ephemeris data files (optional) ----------------------------------
# Without these the backend uses the built-in Moshier model. To use .se1 files,
# mount them into the backend container and point SE_EPHE_PATH at the mount.
SE_EPHE_PATH=
