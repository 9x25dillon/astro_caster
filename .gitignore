# Python
backend/.venv/
__pycache__/
*.pyc
.pytest_cache/
backend/.env

# Docker Compose env (secrets) — commit .env.example instead
/.env

# Node / Vite
frontend/node_modules/
frontend/dist/
frontend/dev-dist/
*.local

# Ephemeris data (large binary files, fetched separately)
backend/ephe/
*.se1
# ...except the small asteroid file vendored for the on-device WASM Swiss engine
!packages/astra-core/src/vendor/swisseph/seas_18.se1

# Telemetry database (local instance data, not committed)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local reports and journals (not source code)
oracle_report_*.txt
course_*.txt
journal/
TASKS.md

# Personal print artifacts (contain birth data) — never commit
*.pdf

# TypeScript incremental build state
*.tsbuildinfo

# Playwright e2e artifacts
frontend/playwright-report/
frontend/test-results/
frontend/e2e/.tokens.json
astra-vault-*.json
