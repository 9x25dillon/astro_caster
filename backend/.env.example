# Backend configuration — copy to .env and edit. All values are optional.

# --- Swiss Ephemeris data files (optional) --------------------------------
# Without these, the engine uses the built-in Moshier model (accurate to a few
# arc-seconds, no files needed). Drop the official .se1 files here for
# arc-second precision and long-range asteroids (Chiron, etc.).
# SE_EPHE_PATH=/home/you/ephe

# --- AI interpretation layer ----------------------------------------------
# If AAE_AI_API_KEY is unset, /api/ai-ask serves a real chart-grounded offline
# reflection (no network). Set a key to use a live LLM.
# Works with any OpenAI-compatible gateway: OpenRouter, Nous Portal, OpenAI...
# AAE_AI_BASE_URL=https://openrouter.ai/api/v1
# AAE_AI_API_KEY=sk-or-...
# AAE_AI_MODEL=anthropic/claude-3.5-sonnet

# --- Premium voice: ElevenLabs TTS (optional) ------------------------------
# Unset -> Astra uses the free browser Web Speech voice. Set a key to enable a
# rich neural voice via /api/tts (selectable in the UI voice bar).
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (warm, calm) — see /api/tts/voices
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Monetization: treasury + open-paywall entitlements --------------------
# Premium features are unlocked by a pay-what-you-want crypto contribution to a
# treasury YOU control. Funds never touch the app. Set your real address:
# AAE_TREASURY_ETH=0xYourEvmAddress          # ETH / Base / Polygon / Arbitrum
# AAE_TREASURY_SOL=YourSolanaAddress         # optional
# AAE_TREASURY_BTC=bc1...                    # optional
# AAE_TREASURY_LABEL=K1ll · Observatory Treasury
# AAE_FUNDING_SPLIT=Music:40,Research:30,Agents:30   # shown in funding dashboard
#
# Entitlement signing + verification:
# AAE_SECRET=set-a-long-random-string        # HMAC secret (REQUIRED in prod — boot is
#                                            #   refused in production without it)
#                                            # ROTATION: rotate AAE_SECRET and
#                                            #   AAE_DEV_TOKEN before sharing this
#                                            #   machine/repo or after any suspected
#                                            #   exposure. Rotating AAE_SECRET
#                                            #   invalidates all issued entitlement
#                                            #   tokens (supporters re-verify their tx).
# AAE_SIGN_ALGO=hmac                         # "ed25519" switches MINTING to asymmetric
#                                            #   signatures a device can verify with only
#                                            #   the public key (mobile roadmap §4.2).
#                                            #   Verification always accepts BOTH schemes,
#                                            #   so flipping this never strands tokens.
# AAE_ED25519_SEED=<64 hex chars>            # REQUIRED with AAE_SIGN_ALGO=ed25519 (prod
#                                            #   boot refused otherwise). Generate with
#                                            #   tools/gen_ed25519_key.py; secret like
#                                            #   AAE_SECRET. Rotation invalidates ed25519
#                                            #   tokens only; HMAC tokens keep verifying.
# AAE_ENT_DAYS=365                           # supporter unlock lifetime
# AAE_ETH_RPC=https://...                    # set to verify tx on-chain (recommended)
# AAE_MIN_WEI=0                              # minimum accepted contribution
# AAE_ORACLE_MIN_WEI=0                       # contribution (wei) that mints ORACLE tier.
#                                            #   0/unset = oracle minting disabled. Only
#                                            #   on-chain-VERIFIED payments qualify — trust
#                                            #   mode can never mint oracle.
#
# --- Oracle Report: Claude Fable 5 (paid, oracle tier) ----------------------
# The enriched report uses the official Anthropic API directly (separate from
# the OpenAI-compatible gateway above). Unset -> deterministic offline report.
# Note: Fable 5 requires 30-day data retention on your Anthropic org (not ZDR),
# and a safety decline is transparently re-served by Opus 4.8 (server-side
# fallback) inside the same call.
# AAE_ANTHROPIC_API_KEY=sk-ant-...
# AAE_ORACLE_REPORT_MODEL=claude-fable-5     # $10/$50 per MTok — budget accordingly
# AAE_ORACLE_REPORT_FALLBACK=claude-opus-4-8
# AAE_ORACLE_REPORT_MAX_TOKENS=16000
# AAE_ORACLE_REPORT_EFFORT=high              # low|medium|high|xhigh|max
#
# Personal Report — deluxe compiled edition (optional post-Oracle product).
# Shares AAE_ANTHROPIC_API_KEY and the fallback model with the Oracle Report.
# AAE_PERSONAL_REPORT_MODEL=claude-fable-5
# AAE_PERSONAL_REPORT_MAX_TOKENS=32000       # 24-36 page PDF target — budget carefully
# AAE_PERSONAL_REPORT_EFFORT=high
#
# PDF-2 — the deluxe edition is a SEPARATE purchase beyond oracle tier:
# /api/personal-report/purchase verifies a treasury tx and mints a report
# claim bound to one Oracle session seed.
# AAE_REPORT_MIN_WEI=0                       # product price (wei). 0/unset = purchases
#                                            #   DISABLED (fail closed). Only on-chain-
#                                            #   VERIFIED payments qualify; dev trust
#                                            #   mode mints unverified (never in prod).
# AAE_REPORT_TOKEN_DAYS=30                   # claim lifetime (recompiles of the same
#                                            #   Oracle session stay allowed until expiry)

# --- Rate limiting (cost protection on the AI paths) ------------------------
# Sliding window per client IP (+ entitlement digest). Default: ON in
# production, OFF in dev/test; set explicitly to override either way.
# AAE_RATE_LIMIT_ENABLED=1                   # 1/0, or unset = auto (prod on, dev off)
# AAE_RATE_LIMIT_AI=20                       # /api/ai-ask*, /api/suggestions,
#                                            #   /api/tarot-reading (include_ai only)
# AAE_RATE_LIMIT_ORACLE=5                    # /api/oracle-report + /api/personal-report
#                                            #   (+ the PDF-2 /purchase rail)
# AAE_RATE_LIMIT_WINDOW_S=60                 # window length in seconds
#
# Deployment environment + trust mode (SECURITY):
# AAE_ENV=development                        # development/dev/local/test/testing = non-prod.
#                                            #   Anything unset/unrecognized = PRODUCTION.
# AAE_TRUST_MODE=1                           # accept unverified tx hashes WITHOUT on-chain
#                                            #   checks — DEV ONLY. Ignored in production, and
#                                            #   the app refuses to boot if set in production.

# --- CORS ------------------------------------------------------------------
# Comma-separated allowed origins. Default "*" is fine for local dev.
# AAE_CORS=http://localhost:5173
